class Solution {
    public boolean isAdjacentDiffAtMostTwo(String s) {
        int n = s.length();
        for(int i=1;i<n;i++){
            int diff = Math.abs((s.charAt(i) - '0') - (s.charAt(i - 1) - '0'));

            if(diff > 2){
                return false;
            }
        }
        return true;
    }
}
