class Solution {
    public int[][] matrixReshape(int[][] mat, int r, int c) {
        int m = mat.length;
        int n = mat[0].length;
        int totalEle = m*n;
        if(totalEle != r*c) return mat;
        int[][] ans = new int[r][c];
        
        for(int i=0;i<totalEle;i++){
            ans[i/c][i%c] = mat[i/n][i%n];
        }
        return ans;
    }
}
