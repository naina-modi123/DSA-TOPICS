class Solution {
    public int furthestDistanceFromOrigin(String moves) {
        int l = 0, r = 0, space = 0;
        for(char ch : moves.toCharArray()){
            if(ch == 'L') l++;
            else if(ch == 'R') r++;
            else space++; 
        }
        return Math.abs(l-r)+space;
    }
}
