class Solution {
    public int countValidSubarrays(int[] nums, int x) {
        int n = nums.length;
        long[] prefix = new long[n+1];
        for(int i=0;i<n;i++){
            prefix[i+1] = prefix[i]+nums[i];
        }
        long ans = 0;
        for(int i=0;i<n;i++){
            for(int j = i;j<n;j++){
                long sum = prefix[j+1] - prefix[i];
                if(sum % 10 != x)continue;

                long firstDigit = sum;
                while(firstDigit >= 10){
                    firstDigit /= 10;
                }
                if(firstDigit == x) ans++;
            }
        }
        return (int)ans;
    }
}
