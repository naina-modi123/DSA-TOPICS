class Solution {
    public long maxSum(int[] nums, int k, int mul) {
        PriorityQueue<Integer> pq = new PriorityQueue<>(Collections.reverseOrder());
        for(int num : nums){
            pq.offer(num);
        }
        long ans = 0;
        int currMul = mul;
        for(int i=0;i<k;i++){
            int x = pq.poll();
            if(currMul > 1){
                ans += (long)x*currMul;
            }else{
                ans += x;
            }
            currMul--;
        }
        return ans;
    }
}
