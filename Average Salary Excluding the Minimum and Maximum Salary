class Solution {
    public double average(int[] salary) {
        int n = salary.length;
        Arrays.sort(salary);
       
        double sum = 0;
        for(int i=0;i<n;i++){
            sum += salary[i];
        }
        sum = sum - salary[0] - salary[n-1];
        return sum/(n-2);
        
    }
}
